# Application
APP_NAME=Document AI Assistant
APP_ENV=development
APP_DEBUG=true

# Database
DATABASE_PROVIDER=sqlite
DATABASE_URL=
DATABASE_FILE=data/maintenance_ai.db

# Vector Database (Qdrant)
QDRANT_MODE=local
QDRANT_PATH=qdrant_data

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=document_chunks
QDRANT_VECTOR_DISTANCE=cosine

# Ollama
OLLAMA_BASE_URL=http://localhost:11434

GENERAL_LLM=qwen3:8b
CLASSIFICATION_LLM=qwen3:8b
QUESTION_GENERATION_LLM=qwen3:8b
EXTRACTION_LLM=qwen3:8b

# Embeddings
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# OCR
OCR_PROVIDER=paddleocr

# Storage Paths
PROJECT_ROOT=
DATA_DIR=data
INPUT_DIR=data/input
OUTPUT_DIR=outputs
PARSED_OUTPUT_DIR=outputs/parsed
IMAGE_OUTPUT_DIR=outputs/images
EXPORT_OUTPUT_DIR=outputs/exports
EVALUATION_OUTPUT_DIR=outputs/evaluation

LOG_DIR=outputs/logs

# Ingestion
MAX_FILE_SIZE_MB=200
MAX_PDF_PAGES=5000

ENABLE_IMAGE_EXTRACTION=true
ENABLE_TABLE_EXTRACTION=true
ENABLE_QUESTION_GENERATION=true

# Chunking
MAX_CHUNK_TOKENS=1000
CHUNK_OVERLAP=150
MIN_SECTION_TEXT_LENGTH=150

# Classification
CLASSIFICATION_ENABLED=true
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.75
CLASSIFICATION_STORE_REASONING=true
CLASSIFICATION_ALLOW_RECLASSIFICATION=true
CLASSIFICATION_USE_RULES=true
CLASSIFICATION_USE_LLM=true
CLASSIFICATION_USE_CACHE=true
CLASSIFICATION_MAX_TEXT_LENGTH=12000
CHUNK_CLASSIFICATION_ENABLED=true
CHUNK_CLASSIFICATION_CONFIDENCE_THRESHOLD=0.70
DOCUMENT_TYPES=manual,datasheet,drawing,certificate,report,unknown

# Duplicate Detection
ENABLE_FILE_HASH_CHECK=true
ENABLE_CONTENT_HASH_CHECK=true

CONTENT_HASH_NORMALIZE_TEXT=true

# Identifier Extraction
ENABLE_IDENTIFIER_EXTRACTION=true
IDENTIFIER_MIN_LENGTH=3

# Question Generation
MAX_GENERATED_QUESTIONS_PER_CHUNK=5
QUESTION_GENERATION_CONFIDENCE_THRESHOLD=0.70

# Retrieval
TOP_K_RETRIEVAL=10

RETRIEVAL_SCORE_THRESHOLD=0.55
RERANK_TOP_K=20

ENABLE_DENSE_RETRIEVAL=true
ENABLE_KEYWORD_RETRIEVAL=true
ENABLE_SQL_RETRIEVAL=true

DENSE_RETRIEVAL_TOP_K=10
KEYWORD_RETRIEVAL_TOP_K=10
SQL_RETRIEVAL_TOP_K=10

FINAL_RETRIEVAL_TOP_K=5

# Agent
AGENT_ENABLED=true

AGENT_MAX_TOOL_CALLS=3

AGENT_ALLOW_DOCUMENT_TOOLS=true
AGENT_ALLOW_RETRIEVAL_TOOLS=true
AGENT_ALLOW_EXTRACTION_TOOLS=true

# LangGraph
LANGGRAPH_ENABLED=true
LANGGRAPH_CHECKPOINTING=false
LANGGRAPH_MAX_STEPS=20

# Memory
ENABLE_SHORT_TERM_MEMORY=true
ENABLE_LONG_TERM_MEMORY=true

MAX_CONVERSATION_MESSAGES=20

# Extraction
EXTRACTION_ENABLED=true
EXTRACTION_CONFIDENCE_THRESHOLD=0.70
EXTRACTION_REQUIRE_HUMAN_REVIEW=true

# Guardrails
MIN_EVIDENCE_CHUNKS=2
REQUIRE_CITATIONS=true



# Validation
VALIDATION_ENABLED=true
FAIL_ON_VALIDATION_ERROR=false

# Events
EVENTS_ENABLED=true

# Evaluation
EVALUATION_ENABLED=true
EVALUATION_DATASET_PATH=data/fixtures/evaluation_dataset.json

# Docling
DOCLING_ENABLE_OCR=false
DOCLING_EXPORT_MARKDOWN=true
DOCLING_EXPORT_JSON=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=outputs/logs/application.log

LOG_ROTATION_SIZE_MB=10
LOG_BACKUP_COUNT=5

LOG_CONSOLE_ENABLED=true
